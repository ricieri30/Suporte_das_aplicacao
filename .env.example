# ============================================
# VPS GUARDIAN - CONFIGURAÇÕES
# ============================================

# --------------------------------------------
# BACKEND
# --------------------------------------------
NODE_ENV=production
PORT=3000

# --------------------------------------------
# MONGODB
# --------------------------------------------
MONGODB_URI=mongodb://vpsguardian:guardian2024@mongodb:27017/vpsguardian?authSource=admin

# --------------------------------------------
# AUTENTICAÇÃO E SEGURANÇA
# --------------------------------------------
JWT_SECRET=vps-guardian-secret-key-MUDE-ISSO-EM-PRODUCAO
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=admin

# --------------------------------------------
# SISTEMA DE BACKUP
# --------------------------------------------
MAX_BACKUPS=6
BACKUP_SCHEDULE=0 1 * * *

# --------------------------------------------
# THRESHOLDS DE ALERTA
# --------------------------------------------
CPU_THRESHOLD=90
MEMORY_THRESHOLD=90
DISK_THRESHOLD=85

# --------------------------------------------
# WEBHOOKS (OPCIONAL)
# --------------------------------------------
WEBHOOK_ENABLED=false
WEBHOOK_URL=
WEBHOOK_TYPE=slack

# Exemplos:
# Slack: https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# Discord: https://discord.com/api/webhooks/YOUR/WEBHOOK/URL
# Telegram: https://api.telegram.org/bot<TOKEN>/sendMessage?chat_id=<CHAT_ID>

# --------------------------------------------
# NOTAS
# --------------------------------------------
# MAX_BACKUPS: Número máximo de backups a manter (padrão: 6)
# BACKUP_SCHEDULE: Cron expression (padrão: 01:00 diariamente)
# CPU_THRESHOLD: % de CPU para alertas (padrão: 90%)
# MEMORY_THRESHOLD: % de RAM para alertas (padrão: 90%)
# DISK_THRESHOLD: % de disco para alertas (padrão: 85%)
